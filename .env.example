# ============================================================
# Orphans World Foundation — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez les vraies valeurs.
# NE JAMAIS committer .env.local sur Git.
# Sur Vercel : ajoutez chaque variable via Settings > Environment Variables.
# ============================================================

# ── Supabase (PUBLIQUES — exposées au navigateur, c'est normal) ─────────────
# Récupérez ces valeurs dans : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://votre-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-cle-anon-publique"

# ── Supabase (SECRÈTE — côté serveur uniquement, jamais de préfixe NEXT_PUBLIC_) ──
# Récupérez cette valeur dans : Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY="votre-cle-service-role-SECRETE"

# ── Nodemailer / Gmail (SECRÈTES — côté serveur uniquement) ─────────────────
# Utilisez un "App Password" Gmail (pas votre mot de passe principal).
# Guide : https://support.google.com/accounts/answer/185833
GMAIL_USER="votre-adresse@gmail.com"
GMAIL_APP_PASSWORD="votre-app-password-gmail"

# ── URL publique du site (optionnel, utilisé pour les métadonnées SEO) ───────
NEXT_PUBLIC_BASE_URL="https://orphansworldfoundation.org"
